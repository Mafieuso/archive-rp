/* Simulation locale pour la démo */
function publierMessage(type, donnees) {
  // En mode démo, on simule la réception immédiate
  setTimeout(() => recevoirMessage(type, { ...donnees, _local: true }), 50);
}

function recevoirMessage(type, donnees) {
  switch (type) {
    case 'joueur:rejoindre':
      if (!etat.joueurs[donnees.id]) {
        etat.joueurs[donnees.id] = { pseudo: donnees.pseudo, role: null, vivant: true, pret: false };
        if (!etat.ordreJoueurs.includes(donnees.id)) etat.ordreJoueurs.push(donnees.id);
        mettreAJourListeAttente();
        mettreAJourListeJeu();
        ajouterLog(`${donnees.pseudo} entre dans le sanctuaire`, 'important');
        afficherToast(`${donnees.pseudo} a rejoint`);
      }
      break;

    case 'joueur:quitter':
      if (etat.joueurs[donnees.id]) {
        ajouterLog(`${etat.joueurs[donnees.id].pseudo} quitte le sanctuaire`, 'danger');
        delete etat.joueurs[donnees.id];
        etat.ordreJoueurs = etat.ordreJoueurs.filter(id => id !== donnees.id);
        mettreAJourListeAttente();
        mettreAJourListeJeu();
        if (etat.estMJ) mettreAJourPanelMJ();
      }
      break;

    case 'jeu:lancer':
      if (!donnees._local || !etat.estMJ) {
        // Distribution des rôles
        const rolesDistrib = donnees.roles;
        etat.ordreJoueurs = donnees.ordreJoueurs;
        donnees.ordreJoueurs.forEach(id => {
          if (etat.joueurs[id]) etat.joueurs[id].role = rolesDistrib[id];
        });
      }
      demarrerJeu();
      break;

    case 'jeu:action-mj':
      executerActionMJ(donnees.action, donnees);
      break;

    case 'nuit:action':
      if (etat.estMJ) {
        etat.actionsNuit[donnees.role] = donnees.cible;
        verifierActionsNuitCompletes();
      }
      break;

    case 'vote:soumettre':
      if (etat.estMJ) {
        etat.votes[donnees.votant] = donnees.cible;
        mettreAJourAffichageVotes();
        verifierVotesComplets();
      }
      break;
  }
}

