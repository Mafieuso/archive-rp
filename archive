      instruction = 'Choisissez une âme dont vous désirez connaître la nature.';
      cibles = jouveursVivantsSauf(etat.monId);
      break;
    case 'potion':
      titre = '⚗️ L\'Herboriste Maudit Agit';
      instruction = etat.potionVieDispo || etat.potionMortDispo
        ? 'Utilisez une de vos potions, ou passez.'
        : 'Vos philtres sont épuisés. Passez.';
      cibles = jouveursVivantsSauf(etat.monId);
      break;
