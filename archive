function selectionnerCible(id, btn) {
  document.querySelectorAll('.btn-cible').forEach(b => b.classList.remove('selectionne'));
  btn.classList.add('selectionne');
  etat.cibleSelectionne = id;
}

function confirmerActionNuit() {
  if (!etat.cibleSelectionne) { afficherToast('Choisissez une cible', 'rouge'); return; }

  const role = ROLES[etat.monRole];
  publierMessage('nuit:action', { role: etat.monRole, cible: etat.cibleSelectionne });
  afficherToast('Votre action a été transmise aux ombres', 'or');
  document.getElementById('zone-action-nuit').classList.remove('active');

  // Remettre l'écran noir
  document.getElementById('ecran-nuit').classList.add('actif');
}

function verifierActionsNuitCompletes() {
  // En mode MJ, résoudre les actions
  resoudreNuit();
}

function resoudreNuit() {
  if (!etat.estMJ) return;

  const attaque    = etat.actionsNuit['premier_eveille'] || etat.actionsNuit['ombre_vorace'];
  const protection = etat.actionsNuit['protecteur_sanctuaire'];
  const potionVie  = etat.actionsNuit['herboriste_vie'];
  const potionMort = etat.actionsNuit['herboriste_mort'];
  const voyance    = etat.actionsNuit['oracle_sang'];

  let victime = attaque;

  // Protection annule l'attaque
  if (protection && protection === attaque) victime = null;

  // Potion de vie sauve la victime
  if (potionVie && potionVie === attaque) { victime = null; etat.potionVieDispo = false; }

  // Potion de mort tue directement
  let victime2 = potionMort;
  if (potionMort) etat.potionMortDispo = false;

  // Appliquer les morts
  if (victime && etat.joueurs[victime]) {
    etat.joueurs[victime].vivant = false;
    etat.derniereMortNuit = victime;
  }
  if (victime2 && etat.joueurs[victime2]) {
    etat.joueurs[victime2].vivant = false;
  }
}

function terminerPhaseNuit() {
  arreterTimer();
  document.getElementById('ecran-nuit').classList.remove('actif');
  document.getElementById('zone-action-nuit').classList.remove('active');
  etat.phase = 'jour';

  // Résoudre la nuit
  if (etat.estMJ) resoudreNuit();

  mettreAJourListeJeu();
  mettreAJourBadgePhase('jour');
  joueurSon('matin');

  // Annoncer les morts
  const mort = etat.derniereMortNuit;
  if (mort && etat.joueurs[mort]) {
    const nomMort = etat.joueurs[mort].pseudo;
    mettreAJourEtatJeu(`☀️ L'aube révèle une tragédie...`, `${nomMort} a été consumé par les Ombres cette nuit.`);
    ajouterLog(`${nomMort} a été retrouvé mort à l'aube.`, 'danger');
  } else {
    mettreAJourEtatJeu('☀️ L\'aube se lève sur le sanctuaire', 'Personne n\'est mort cette nuit. Les ombres ont été vaincues.');
    ajouterLog('Nuit paisible — aucun mort.', 'important');
  }

  etat.derniereMortNuit = null;
  verifierConditionsVictoire();
}

