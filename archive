   ============================================================ */
function demarrerJeu() {
  // Appliquer les rôles
  etat.ordreJoueurs.forEach(id => {
    const roleId = etat.joueurs[id]?.role;
    if (id === etat.monId && roleId) etat.monRole = roleId;
  });

  // Aller à l'écran de jeu
  changerEcran('ecran-jeu');

  if (etat.estMJ) document.getElementById('panel-mj').style.display = 'block';

  mettreAJourListeJeu();
  if (etat.estMJ) mettreAJourPanelMJ();

  // Animation d'entrée de la carte de rôle
  setTimeout(() => afficherCarteRole(), 500);

  // Premier log
