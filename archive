function executerActionMJ(action, donnees) {
  switch (action) {
    case 'pause':
      afficherToast('Partie en pause', 'or');
      mettreAJourEtatJeu('⏸ Pause', 'Le Maître du Jeu a suspendu la partie.');
      arreterTimer();
      break;

    case 'nuit':
      demarrerPhaseNuit();
      break;

    case 'reveil':
      terminerPhaseNuit();
      break;

    case 'vote':
      demarrerPhaseVote();
      break;

    case 'prochaine-phase':
      passerPhase();
      break;

    case 'fin':
      if (etat.estMJ) {
        const gagnants = window.prompt ? prompt("Qui gagne ? (loups/village/ombre-blanche)") : 'village';
        terminerPartie(gagnants || 'village');
      }
      break;
