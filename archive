/* ============================================================
   LANCEMENT DE LA PARTIE (MJ SEULEMENT)
   ============================================================ */
function lancerPartie() {
  if (!etat.estMJ) return;
  if (etat.ordreJoueurs.length < 5) { afficherToast('Minimum 5 joueurs requis', 'rouge'); return; }

  // Mélanger les rôles
  const nb = etat.ordreJoueurs.length;
  const rolesList = calculerDistribution(nb);
  const rolesMelanges = melangerTableau([...rolesList]);

  // Attribuer les rôles
  const rolesDistrib = {};
  etat.ordreJoueurs.forEach((id, i) => {
    rolesDistrib[id] = rolesMelanges[i];
  });

  // Mon propre rôle
  etat.monRole = rolesDistrib[etat.monId];

  // Publier le lancement
  publierMessage('jeu:lancer', {
    roles: rolesDistrib,
    ordreJoueurs: etat.ordreJoueurs,
  });
}

