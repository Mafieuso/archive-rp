  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
  gap: 0.5rem;
  margin-top: 0.8rem;
}

.btn-cible {
  padding: 0.5rem 0.6rem;
  background: rgba(26,10,10,0.8);
  border: 1px solid var(--bordure-rouge);
  color: var(--texte-principal);
  border-radius: var(--rayon);
