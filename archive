<script src="https://cdn.ably.com/lib/ably.min-2.js"></script>

<style>
/* ============================================================
   VARIABLES GLOBALES — THÈME DÉMONIAQUE SOMBRE
   ============================================================ */
:root {
  --noir:           #0a0a0f;
  --noir-profond:   #050508;
  --charbon:        #111118;
  --charbon-clair:  #1a1a26;
  --rouge-sang:     #8b0000;
  --rouge-vif:      #c0392b;
  --rouge-lueur:    #e74c3c;
  --or-terni:       #b8960c;
  --or-clair:       #d4af37;
  --or-pale:        #f0d060;
  --brume:          rgba(139,0,0,0.08);
  --texte-principal:#e8d5c4;
  --texte-doux:     #a89070;
  --texte-ombre:    #6a5040;
  --bordure-or:     rgba(180,140,12,0.4);
  --bordure-rouge:  rgba(139,0,0,0.6);
  --ombre-rouge:    0 0 20px rgba(139,0,0,0.5);
  --ombre-or:       0 0 15px rgba(184,150,12,0.4);
  --rayon:          4px;
}

/* ============================================================
   RESET & BASE
   ============================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background-color: var(--noir-profond);
  color: var(--texte-principal);
  font-family: 'Georgia', 'Times New Roman', serif;
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* ============================================================
   ANIMATION BRUME DE FOND
   ============================================================ */
.fog-container {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.fog-layer {
  position: absolute;
  width: 200%;
  height: 100%;
  background: radial-gradient(ellipse 60% 40% at 50% 50%,
    rgba(139,0,0,0.12) 0%,
    rgba(100,0,0,0.06) 40%,
    transparent 70%);
  animation: fogDrift 18s ease-in-out infinite alternate;
  opacity: 0.7;
}

.fog-layer:nth-child(2) {
  animation-duration: 25s;
  animation-direction: alternate-reverse;
  background: radial-gradient(ellipse 80% 60% at 30% 70%,
    rgba(80,0,0,0.1) 0%, transparent 60%);
}

.fog-layer:nth-child(3) {
  animation-duration: 32s;
  background: radial-gradient(ellipse 50% 80% at 70% 30%,
    rgba(120,0,0,0.08) 0%, transparent 55%);
}

@keyframes fogDrift {
  from { transform: translateX(-10%) scale(1); }
  to   { transform: translateX(10%) scale(1.05); }
}

/* Particules flottantes */
.particle {
  position: fixed;
  width: 2px;
  height: 2px;
  border-radius: 50%;
  pointer-events: none;
  z-index: 1;
  animation: particleFloat linear infinite;
}

@keyframes particleFloat {
  0%   { transform: translateY(100vh) translateX(0); opacity: 0; }
  10%  { opacity: 0.6; }
  90%  { opacity: 0.3; }
  100% { transform: translateY(-10vh) translateX(var(--drift)); opacity: 0; }
}

/* Motif de fond — sigils répétés */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(139,0,0,0.04) 50px),
    repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(139,0,0,0.04) 50px);
  z-index: 0;
  pointer-events: none;
}

/* ============================================================
   WRAPPER PRINCIPAL
   ============================================================ */
#app-wrapper {
  position: relative;
  z-index: 10;
  min-height: 100vh;
}

/* ============================================================
   HEADER — TITRE PRINCIPAL
   ============================================================ */
.site-header {
  text-align: center;
  padding: 2.5rem 1rem 1.5rem;
  position: relative;
}

.site-header::after {
  content: '';
  display: block;
  width: 60%;
  max-width: 400px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--or-terni), transparent);
  margin: 1rem auto 0;
}

.titre-principal {
  font-size: clamp(1.6rem, 5vw, 3.2rem);
  font-weight: 900;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--rouge-sang);
  text-shadow: 0 0 30px rgba(139,0,0,0.7), 0 0 60px rgba(139,0,0,0.3);
  line-height: 1.1;
}

.sous-titre {
  font-size: clamp(0.75rem, 2vw, 1rem);
  color: var(--or-terni);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-top: 0.5rem;
  opacity: 0.8;
}

/* ============================================================
   BORDURES CALLIGRAPHIÉES — COMPOSANT RÉUTILISABLE
   ============================================================ */
.cadre-calligraphie {
  position: relative;
  border: 1px solid var(--bordure-or);
  border-radius: var(--rayon);
}

.cadre-calligraphie::before,
.cadre-calligraphie::after {
  content: '';
  position: absolute;
  width: 12px;
  height: 12px;
  border-color: var(--or-terni);
  border-style: solid;
}

.cadre-calligraphie::before {
  top: -1px; left: -1px;
  border-width: 2px 0 0 2px;
}

.cadre-calligraphie::after {
  bottom: -1px; right: -1px;
  border-width: 0 2px 2px 0;
}

/* ============================================================
   ÉCRANS (vues de l'application)
   ============================================================ */
.ecran {
  display: none;
  padding: 1rem;
  max-width: 960px;
  margin: 0 auto;
  animation: fonduEntree 0.6s ease;
}

.ecran.actif { display: block; }

@keyframes fonduEntree {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* ============================================================
   ÉCRAN D'ACCUEIL
   ============================================================ */
.accueil-centre {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rem;
  padding-top: 1rem;
}

.logo-demon {
  font-size: 5rem;
  line-height: 1;
  filter: drop-shadow(0 0 20px rgba(139,0,0,0.8));
  animation: pulseLogo 3s ease-in-out infinite;
}

@keyframes pulseLogo {
  0%,100% { filter: drop-shadow(0 0 20px rgba(139,0,0,0.8)); transform: scale(1); }
  50%      { filter: drop-shadow(0 0 40px rgba(139,0,0,1)); transform: scale(1.05); }
}

.separateur-decoratif {
  display: flex;
  align-items: center;
  gap: 1rem;
  width: 100%;
  max-width: 420px;
  color: var(--or-terni);
  font-size: 0.75rem;
  letter-spacing: 0.2em;
}

.separateur-decoratif::before,
.separateur-decoratif::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--bordure-or));
}

.separateur-decoratif::after {
  background: linear-gradient(90deg, var(--bordure-or), transparent);
}

.panneau-accueil {
  width: 100%;
  max-width: 440px;
  background: rgba(10,10,15,0.85);
  backdrop-filter: blur(4px);
  padding: 2rem;
}

.panneau-accueil h2 {
  text-align: center;
  color: var(--or-terni);
  font-size: 1rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
}

.champ-groupe {
  margin-bottom: 1.2rem;
}

.champ-groupe label {
  display: block;
  font-size: 0.75rem;
  color: var(--texte-doux);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-bottom: 0.4rem;
}

.champ-saisie {
  width: 100%;
  padding: 0.7rem 1rem;
  background: rgba(26,26,38,0.9);
  border: 1px solid var(--bordure-rouge);
  border-radius: var(--rayon);
  color: var(--texte-principal);
  font-family: inherit;
  font-size: 1rem;
  transition: border-color 0.3s, box-shadow 0.3s;
  outline: none;
}

.champ-saisie:focus {
  border-color: var(--rouge-vif);
  box-shadow: var(--ombre-rouge);
}

.champ-saisie::placeholder { color: var(--texte-ombre); }

/* Boutons */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: var(--rayon);
  font-family: inherit;
  font-size: 0.9rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  cursor: pointer;
  transition: all 0.25s;
  position: relative;
  overflow: hidden;
}

.btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(255,255,255,0.05);
  opacity: 0;
  transition: opacity 0.2s;
}

.btn:hover::after { opacity: 1; }
.btn:active { transform: scale(0.97); }

.btn-primaire {
  width: 100%;
  background: var(--rouge-sang);
  color: var(--texte-principal);
  box-shadow: var(--ombre-rouge);
}

.btn-primaire:hover {
  background: var(--rouge-vif);
  box-shadow: 0 0 30px rgba(192,57,43,0.6);
}

.btn-or {
  width: 100%;
  background: transparent;
  border: 1px solid var(--or-terni);
  color: var(--or-clair);
}

.btn-or:hover {
  background: rgba(180,140,12,0.1);
  box-shadow: var(--ombre-or);
}

.btn-danger {
  background: rgba(139,0,0,0.3);
  border: 1px solid var(--rouge-sang);
  color: var(--rouge-lueur);
  padding: 0.4rem 0.8rem;
  font-size: 0.75rem;
}

.btn-danger:hover { background: rgba(139,0,0,0.5); }

.btn-neutre {
  background: rgba(26,26,38,0.8);
  border: 1px solid var(--bordure-or);
  color: var(--texte-doux);
}

.btn-neutre:hover { border-color: var(--or-terni); color: var(--or-clair); }

/* ============================================================
   LISTE DES JOUEURS DANS L'ACCUEIL
   ============================================================ */
.liste-joueurs-accueil {
  margin-top: 1.5rem;
  border-top: 1px solid var(--bordure-rouge);
  padding-top: 1rem;
}

.liste-joueurs-accueil h3 {
  font-size: 0.8rem;
  letter-spacing: 0.15em;
  color: var(--texte-doux);
  text-transform: uppercase;
  margin-bottom: 0.8rem;
}

.item-joueur-accueil {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.4rem 0.6rem;
  background: rgba(26,26,38,0.5);
  border-left: 2px solid var(--rouge-sang);
  margin-bottom: 0.4rem;
  border-radius: 0 var(--rayon) var(--rayon) 0;
  font-size: 0.9rem;
  animation: glisserEntree 0.3s ease;
}

@keyframes glisserEntree {
  from { transform: translateX(-10px); opacity: 0; }
  to   { transform: translateX(0); opacity: 1; }
}

.pastille-mj {
  font-size: 0.65rem;
  background: var(--rouge-sang);
  color: var(--or-pale);
  padding: 0.1rem 0.4rem;
  border-radius: 2px;
  letter-spacing: 0.05em;
}

/* ============================================================
   PANEL MJ (Maître du Jeu)
   ============================================================ */
.panel-mj {
  background: rgba(20,10,10,0.95);
  border: 1px solid var(--rouge-sang);
  border-radius: var(--rayon);
  padding: 1.2rem;
  margin-bottom: 1.5rem;
}

.panel-mj-titre {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 0.8rem;
  letter-spacing: 0.2em;
  color: var(--rouge-lueur);
  text-transform: uppercase;
  margin-bottom: 1rem;
  padding-bottom: 0.6rem;
  border-bottom: 1px solid var(--bordure-rouge);
}

.panel-mj-titre::before { content: '👁'; font-size: 1rem; }

.grille-controles {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 0.6rem;
  margin-bottom: 1rem;
}

.btn-controle {
  padding: 0.6rem 0.8rem;
  font-size: 0.75rem;
  text-align: center;
  background: rgba(10,10,15,0.8);
  border: 1px solid var(--bordure-rouge);
  color: var(--texte-principal);
  border-radius: var(--rayon);
  cursor: pointer;
  transition: all 0.2s;
  font-family: inherit;
  letter-spacing: 0.05em;
}

.btn-controle:hover {
  border-color: var(--rouge-vif);
  background: rgba(139,0,0,0.2);
  box-shadow: var(--ombre-rouge);
}

.btn-controle.actif {
  background: var(--rouge-sang);
  border-color: var(--rouge-vif);
}

.btn-controle:disabled { opacity: 0.3; cursor: not-allowed; }

/* Liste joueurs MJ avec rôles visibles */
.liste-mj-joueurs { margin-top: 1rem; }

.ligne-mj-joueur {
  display: grid;
  grid-template-columns: 1fr auto auto;
  align-items: center;
  gap: 0.5rem;
  padding: 0.5rem 0.6rem;
  border-bottom: 1px solid rgba(139,0,0,0.15);
}

.ligne-mj-joueur:last-child { border-bottom: none; }

.mj-joueur-nom { font-size: 0.9rem; }

.badge-role {
  font-size: 0.65rem;
  padding: 0.15rem 0.5rem;
  border-radius: 2px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  font-weight: bold;
}

.role-loup    { background: rgba(139,0,0,0.4); color: #ff6b6b; border: 1px solid var(--rouge-sang); }
.role-blanc   { background: rgba(200,200,200,0.1); color: #ddd; border: 1px solid rgba(200,200,200,0.3); }
.role-voyante { background: rgba(100,0,150,0.3); color: #c890ff; border: 1px solid rgba(150,0,200,0.4); }
.role-sorciere{ background: rgba(0,80,0,0.3); color: #90ff90; border: 1px solid rgba(0,150,0,0.4); }
.role-garde   { background: rgba(0,60,120,0.3); color: #90c0ff; border: 1px solid rgba(0,100,200,0.4); }
.role-villageois { background: rgba(80,60,20,0.3); color: #d4af37; border: 1px solid rgba(150,120,30,0.4); }

/* ============================================================
   ZONE DE JEU PRINCIPALE
   ============================================================ */
.zone-jeu {
  display: grid;
  grid-template-columns: 1fr 280px;
  gap: 1rem;
}

@media (max-width: 700px) {
  .zone-jeu { grid-template-columns: 1fr; }
}

/* Centre de jeu */
.centre-jeu {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

/* ============================================================
   AFFICHAGE DE L'ÉTAT DU JEU — TEXTE CENTRAL
   ============================================================ */
.etat-jeu-banniere {
  text-align: center;
  padding: 1.5rem;
  position: relative;
  min-height: 100px;
}

.etat-jeu-texte {
  font-size: clamp(1rem, 3vw, 1.5rem);
  color: var(--or-clair);
  text-shadow: var(--ombre-or);
  letter-spacing: 0.05em;
  animation: pulseTexte 2s ease-in-out infinite;
  line-height: 1.4;
}

@keyframes pulseTexte {
  0%,100% { text-shadow: 0 0 10px rgba(212,175,55,0.4); }
  50%      { text-shadow: 0 0 25px rgba(212,175,55,0.8), 0 0 50px rgba(212,175,55,0.3); }
}

.etat-jeu-sous-texte {
  font-size: 0.85rem;
  color: var(--texte-doux);
  margin-top: 0.5rem;
  font-style: italic;
}

/* Timer */
.timer-cercle {
  position: relative;
  width: 80px;
  height: 80px;
  margin: 0.5rem auto;
}

.timer-svg { transform: rotate(-90deg); }

.timer-piste {
  fill: none;
  stroke: rgba(139,0,0,0.2);
  stroke-width: 4;
}

.timer-barre {
  fill: none;
  stroke: var(--rouge-sang);
  stroke-width: 4;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s linear, stroke 0.5s;
  stroke-dasharray: 226;
  stroke-dashoffset: 0;
}

.timer-nombre {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.3rem;
  font-weight: bold;
  color: var(--rouge-lueur);
}

/* ============================================================
   CARTE DE RÔLE — ANIMATION PRINCIPALE
   ============================================================ */
.zone-carte-role {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 180px;
  position: relative;
}

.carte-role {
  width: 160px;
  height: 220px;
  position: relative;
  cursor: pointer;
  perspective: 800px;
  flex-shrink: 0;
}

.carte-role-interieur {
  width: 100%;
  height: 100%;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s ease;
}

.carte-role:hover .carte-role-interieur {
  transform: rotateY(180deg);
}

.carte-face, .carte-dos {
  position: absolute;
  inset: 0;
  backface-visibility: hidden;
  border-radius: 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  text-align: center;
}

.carte-face {
  background: linear-gradient(160deg, #1a0a0a 0%, #0d0d1a 100%);
  border: 2px solid var(--or-terni);
  box-shadow: 0 0 20px rgba(139,0,0,0.4), inset 0 0 20px rgba(0,0,0,0.5);
}

.carte-dos {
  background: linear-gradient(160deg, #0d0a1a 0%, #1a0a0a 100%);
  border: 2px solid var(--bordure-rouge);
  box-shadow: var(--ombre-rouge);
  transform: rotateY(180deg);
  font-size: 0.75rem;
  color: var(--texte-doux);
  padding: 0.8rem;
  overflow: hidden;
}

.carte-role-icone {
  font-size: 2.5rem;
  margin-bottom: 0.5rem;
  filter: drop-shadow(0 0 8px rgba(212,175,55,0.6));
  animation: iconePulse 3s ease-in-out infinite;
}

@keyframes iconePulse {
  0%,100% { filter: drop-shadow(0 0 8px rgba(212,175,55,0.6)); }
  50%      { filter: drop-shadow(0 0 16px rgba(212,175,55,1)); }
}

.carte-role-nom {
  font-size: 0.85rem;
  font-weight: bold;
  color: var(--or-clair);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.carte-role-type {
  font-size: 0.65rem;
  color: var(--texte-ombre);
  margin-top: 0.2rem;
  letter-spacing: 0.1em;
}

/* Animation d'entrée de la carte */
@keyframes carteArrivee {
  0%   { transform: scale(0.2) translateY(-50vh); opacity: 0; }
  60%  { transform: scale(1.15); }
  75%  { transform: scale(0.95) rotate(-2deg); }
  85%  { transform: scale(1.05) rotate(1deg); }
  100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.carte-role.anime { animation: carteArrivee 1.2s cubic-bezier(0.22,1,0.36,1) forwards; }

/* Particules autour de la carte */
.particule-carte {
  position: absolute;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--or-terni);
  pointer-events: none;
  animation: particuleCarte 1s ease-out forwards;
}

@keyframes particuleCarte {
  0%   { opacity: 1; transform: translate(0,0) scale(1); }
  100% { opacity: 0; transform: translate(var(--tx), var(--ty)) scale(0); }
}

/* ============================================================
   COLONNE DROITE — LISTE JOUEURS EN JEU
   ============================================================ */
.colonne-joueurs {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.colonne-joueurs-titre {
  font-size: 0.75rem;
  letter-spacing: 0.2em;
  color: var(--texte-doux);
  text-transform: uppercase;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--bordure-rouge);
}

.item-joueur-jeu {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  padding: 0.5rem 0.7rem;
  background: rgba(10,10,15,0.6);
  border-radius: var(--rayon);
  border: 1px solid rgba(139,0,0,0.2);
  transition: border-color 0.3s;
  position: relative;
}

.item-joueur-jeu:hover { border-color: var(--rouge-sang); }

.joueur-vivant  { opacity: 1; }
.joueur-mort    { opacity: 0.4; text-decoration: line-through; }

.dot-statut {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-vivant { background: #2ecc71; box-shadow: 0 0 6px rgba(46,204,113,0.6); }
.dot-mort   { background: var(--rouge-sang); }

.joueur-nom-jeu { font-size: 0.9rem; flex: 1; }

/* ============================================================
   LOG DES ÉVÉNEMENTS
   ============================================================ */
.log-evenements {
  max-height: 180px;
  overflow-y: auto;
  padding: 0.8rem;
  background: rgba(5,5,8,0.8);
  border-radius: var(--rayon);
  border: 1px solid var(--bordure-rouge);
  scrollbar-width: thin;
  scrollbar-color: var(--rouge-sang) var(--charbon);
}

.log-evenements::-webkit-scrollbar { width: 4px; }
.log-evenements::-webkit-scrollbar-track { background: var(--charbon); }
.log-evenements::-webkit-scrollbar-thumb { background: var(--rouge-sang); }

.log-entree {
  font-size: 0.8rem;
