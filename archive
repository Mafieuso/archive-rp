/* Distribution selon le nombre de joueurs */
function calculerDistribution(nbJoueurs) {
  const nbLoups = Math.max(1, Math.floor(nbJoueurs / 4));
  const dist = [];

  // Premier Éveillé (toujours 1)
  dist.push('premier_eveille');

  // Loups supplémentaires
  for (let i = 1; i < nbLoups; i++) dist.push('ombre_vorace');

  // Rôles spéciaux villageois
  dist.push('oracle_sang');
  if (nbJoueurs >= 6)  dist.push('herboriste_maudit');
  if (nbJoueurs >= 8)  dist.push('protecteur_sanctuaire');

  // Reste = âmes ordinaires
  while (dist.length < nbJoueurs) dist.push('ame_ordinaire');

  return dist;
}

