   ============================================================ */
.zone-vote {
  padding: 1rem;
  background: rgba(10,8,5,0.9);
  border: 1px solid var(--bordure-or);
  border-radius: var(--rayon);
  display: none;
}

.zone-vote.active { display: block; }

.zone-vote h3 {
  font-size: 0.9rem;
  color: var(--or-clair);
  letter-spacing: 0.1em;
  margin-bottom: 0.8rem;
  text-transform: uppercase;
}

.barre-vote {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.5rem;
  font-size: 0.85rem;
}

.barre-vote-fond {
  flex: 1;
  height: 8px;
  background: rgba(26,26,38,0.8);
  border-radius: 4px;
  overflow: hidden;
}

.barre-vote-remplissage {
  height: 100%;
  background: var(--rouge-sang);
  transition: width 0.5s ease;
  box-shadow: 0 0 6px rgba(139,0,0,0.5);
}

/* ============================================================
   ÉCRAN NOIR — SOMMEIL FORCÉ
   ============================================================ */
#ecran-nuit {
  position: fixed;
  inset: 0;
  background: #000;
  z-index: 9999;
  display: none;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 1.5rem;
}

#ecran-nuit.actif { display: flex; }

.lune-icone {
  font-size: 4rem;
  animation: luneRotation 8s linear infinite;
  filter: drop-shadow(0 0 20px rgba(100,100,200,0.5));
}

@keyframes luneRotation {
  from { transform: rotate(0deg) scale(1); }
  50%  { transform: rotate(180deg) scale(1.1); }
  to   { transform: rotate(360deg) scale(1); }
}

.texte-nuit {
  color: rgba(100,100,180,0.7);
  font-size: 1.1rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  animation: texteNuitFade 3s ease-in-out infinite;
}

@keyframes texteNuitFade {
  0%,100% { opacity: 0.4; }
  50%      { opacity: 0.9; }
}

/* ============================================================
   NOTIFICATION TOAST
   ============================================================ */
#toast-container {
  position: fixed;
  top: 1rem;
  right: 1rem;
  z-index: 10000;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  pointer-events: none;
}

.toast {
  padding: 0.7rem 1rem;
  background: rgba(10,10,15,0.95);
  border-left: 3px solid var(--rouge-sang);
  border-radius: 0 var(--rayon) var(--rayon) 0;
  font-size: 0.85rem;
  color: var(--texte-principal);
  max-width: 280px;
  animation: toastEntree 0.3s ease;
  backdrop-filter: blur(4px);
}

.toast.or { border-left-color: var(--or-terni); color: var(--or-clair); }
.toast.vert { border-left-color: #2ecc71; }

@keyframes toastEntree {
  from { transform: translateX(100%); opacity: 0; }
  to   { transform: translateX(0); opacity: 1; }
}

/* ============================================================
   ÉCRAN FIN DE PARTIE
   ============================================================ */
.ecran-fin {
  text-align: center;
  padding: 3rem 1rem;
}

.victoire-titre {
  font-size: clamp(2rem, 6vw, 4rem);
  font-weight: 900;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  animation: victoireAnim 2s ease-in-out infinite;
}

@keyframes victoireAnim {
  0%,100% { text-shadow: 0 0 20px currentColor; }
  50%      { text-shadow: 0 0 60px currentColor, 0 0 100px currentColor; }
}

.victoire-loups    { color: var(--rouge-sang); }
.victoire-village  { color: var(--or-clair); }

