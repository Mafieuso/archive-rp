}

function verifierVotesComplets() {
  const nbVivants = jouveursVivantsSauf(null).length;
  if (Object.keys(etat.votes).length >= nbVivants) resoudreVote();
}

function resoudreVote() {
  arreterTimer();
  document.getElementById('zone-vote').classList.remove('active');

  // Trouver le plus voté
  const comptage = {};
  Object.values(etat.votes).forEach(id => { comptage[id] = (comptage[id] || 0) + 1; });

  let maxVotes = 0;
  let elimine = null;
  Object.entries(comptage).forEach(([id, nb]) => {
    if (nb > maxVotes) { maxVotes = nb; elimine = id; }
  });

  if (elimine && etat.joueurs[elimine]) {
    etat.joueurs[elimine].vivant = false;
    const j = etat.joueurs[elimine];
    const roleNom = ROLES[j.role]?.nom || '???';
    mettreAJourEtatJeu(`⚔️ Sentence exécutée`, `${j.pseudo} est banni du sanctuaire — il était : ${roleNom}`);
    ajouterLog(`${j.pseudo} (${roleNom}) a été banni par le conseil.`, 'danger');
    joueurSon('cri');
  } else {
    mettreAJourEtatJeu('⚖️ Égalité', 'Le conseil ne parvient pas à un accord. Personne n\'est éliminé.');
  }

  mettreAJourListeJeu();
  verifierConditionsVictoire();
}

function passerPhase() {
  if (etat.phase === 'jour' || etat.phase === 'vote') {
    executerActionMJ('nuit', {});
  } else if (etat.phase === 'nuit') {
    terminerPhaseNuit();
  }
}

/* ============================================================
   CONDITIONS DE VICTOIRE
   ============================================================ */
function verifierConditionsVictoire() {
  if (!etat.estMJ) return;

  const vivants = jouveursVivantsSauf(null);
  const loups = vivants.filter(id => ROLES[etat.joueurs[id]?.role]?.camp === 'loups');
  const village = vivants.filter(id => ROLES[etat.joueurs[id]?.role]?.camp === 'village');

  // Victoire des Loups
  if (loups.length >= village.length) {
    terminerPartie('loups');
    return;
  }

  // Victoire du Village
  if (loups.length === 0) {
    terminerPartie('village');
    return;
  }

  // Victoire Loup Blanc (seul survivant loup)
  if (loups.length === 1 && vivants.length === 1) {
    terminerPartie('ombre-blanche');
  }
}

function terminerPartie(gagnant) {
  etat.phase = 'fin';
  arreterTimer();

  const ecranFin = document.getElementById('ecran-fin');
  const titreVictoire = document.getElementById('victoire-titre');
  const descVictoire = document.getElementById('victoire-description');
  const iconeVictoire = document.getElementById('victoire-icone');
  const resumeRoles = document.getElementById('resume-roles');

  let titre, desc, icone, classeVictoire;

  switch (gagnant) {
    case 'loups':
      titre = 'Les Ombres Triomphent';
      desc = 'Les démons ont consumé le sanctuaire. Leurs masques tombent, révélant la vérité terrible — le mal régnait parmi les innocents.';
      icone = '🔥';
      classeVictoire = 'victoire-loups';
      break;
    case 'village':
      titre = 'Le Village est Sauvé';
      desc = 'La lumière a triomphé des ténèbres. Les habitants du sanctuaire ont démasqué les démons et restauré la paix.';
      icone = '🏮';
      classeVictoire = 'victoire-village';
      break;
    case 'ombre-blanche':
      titre = 'Le Premier Éveillé Règne';
      desc = 'Le loup blanc solitaire remporte une victoire écrasante. Sa ruse diabolique a éliminé loups et villageois pour régner seul.';
      icone = '🐺';
      classeVictoire = 'victoire-loups';
      break;
  }

  titreVictoire.textContent = titre;
  titreVictoire.className = `victoire-titre ${classeVictoire}`;
  descVictoire.textContent = desc;
  iconeVictoire.textContent = icone;

  // Résumé des rôles
  resumeRoles.innerHTML = '<div style="font-size:0.75rem;letter-spacing:0.15em;color:var(--texte-doux);text-transform:uppercase;margin-bottom:0.8rem;">Révélation des Âmes</div>';
  etat.ordreJoueurs.forEach(id => {
    const j = etat.joueurs[id];
    if (!j) return;
    const role = ROLES[j.role] || ROLES['ame_ordinaire'];
    const div = document.createElement('div');
    div.style.cssText = 'display:flex;align-items:center;gap:0.6rem;padding:0.4rem;margin-bottom:0.3rem;background:rgba(10,10,15,0.6);border-radius:4px;';
    div.innerHTML = `
      <span>${role.icone}</span>
      <span style="flex:1;">${j.pseudo}</span>
      <span class="badge-role ${role.couleur}">${role.nom}</span>
      ${!j.vivant ? '<span style="font-size:0.7rem;color:var(--rouge-lueur);">✝ éliminé</span>' : ''}
    `;
    resumeRoles.appendChild(div);
  });

  changerEcran('ecran-fin');
}

/* ============================================================
   TIMER
   ============================================================ */
function demarrerTimer(secondes, callback) {
  arreterTimer();
  etat.timerRestant = secondes;
  const total = secondes;
  const circumference = 226;

  document.getElementById('zone-timer').style.display = 'block';

  function tick() {
    const restant = etat.timerRestant;
    document.getElementById('timer-nombre').textContent = restant;
    const barre = document.getElementById('timer-barre-svg');
    const offset = circumference * (1 - restant / total);
    barre.style.strokeDashoffset = offset;

    // Couleur d'urgence
    if (restant <= 10) {
      barre.style.stroke = 'var(--rouge-lueur)';
      document.getElementById('timer-nombre').style.color = 'var(--rouge-lueur)';
    } else {
      barre.style.stroke = 'var(--rouge-sang)';
      document.getElementById('timer-nombre').style.color = 'var(--rouge-lueur)';
    }

    etat.timerRestant--;

    if (etat.timerRestant < 0) {
      arreterTimer();
      if (callback) callback();
    }
  }

  tick();
  etat.timerInterval = setInterval(tick, 1000);
}

function arreterTimer() {
  if (etat.timerInterval) {
    clearInterval(etat.timerInterval);
    etat.timerInterval = null;
  }
  const zone = document.getElementById('zone-timer');
  if (zone) zone.style.display = 'none';
}

/* ============================================================
   INTERFACE — MISES À JOUR
   ============================================================ */
function mettreAJourEtatJeu(texte, sousTexte) {
  const t = document.getElementById('texte-etat-jeu');
  const s = document.getElementById('sous-texte-etat-jeu');
  if (t) t.textContent = texte;
  if (s) s.textContent = sousTexte || '';
}

function mettreAJourBadgePhase(phase) {
  const badge = document.getElementById('badge-phase-actuelle');
  if (!badge) return;
  const configs = {
    nuit: { classe: 'phase-nuit', texte: '🌑 Nuit' },
    jour: { classe: 'phase-jour', texte: '☀️ Jour' },
    vote: { classe: 'phase-vote', texte: '⚖️ Vote' },
  };
  const cfg = configs[phase] || configs['jour'];
  badge.className = `badge-phase ${cfg.classe}`;
  badge.textContent = cfg.texte;
}

function mettreAJourListeJeu() {
  const liste = document.getElementById('liste-joueurs-jeu');
  if (!liste) return;
  liste.innerHTML = '';

  etat.ordreJoueurs.forEach(id => {
    const j = etat.joueurs[id];
    if (!j) return;
    const div = document.createElement('div');
    div.className = `item-joueur-jeu ${j.vivant ? 'joueur-vivant' : 'joueur-mort'}`;
    div.innerHTML = `
      <div class="dot-statut ${j.vivant ? 'dot-vivant' : 'dot-mort'}"></div>
      <span class="joueur-nom-jeu">${j.pseudo}${id === etat.monId ? ' (Moi)' : ''}</span>
      ${j.estMJ ? '<span class="pastille-mj">MJ</span>' : ''}
    `;
    liste.appendChild(div);
  });
}

function mettreAJourPanelMJ() {
  const liste = document.getElementById('liste-mj-joueurs');
  if (!liste) return;
  liste.innerHTML = '';

  etat.ordreJoueurs.forEach(id => {
    const j = etat.joueurs[id];
    if (!j) return;
    const role = ROLES[j.role];
    const div = document.createElement('div');
    div.className = 'ligne-mj-joueur';
    div.innerHTML = `
      <span class="mj-joueur-nom">${j.pseudo}${!j.vivant ? ' ✝' : ''}</span>
      ${role ? `<span class="badge-role ${role.couleur}">${role.icone} ${role.nom}</span>` : '<span style="color:var(--texte-ombre);font-size:0.75rem;">—</span>'}
      <button class="btn btn-danger" onclick="exclureJoueur('${id}')" title="Exclure" ${j.estMJ ? 'style="display:none"' : ''}>✕</button>
    `;
    liste.appendChild(div);
  });
}

/* ============================================================
   EXCLUSION (KICK) — MJ SEULEMENT
   ============================================================ */
function exclureJoueur(id) {
  if (!etat.estMJ || id === etat.monId) return;
  const j = etat.joueurs[id];
  if (!j) return;
  if (!confirm(`Exclure ${j.pseudo} de la session ?`)) return;

  ajouterLog(`${j.pseudo} a été banni du sanctuaire par le MJ.`, 'danger');
  publierMessage('joueur:quitter', { id });
}

/* ============================================================
   LOG DES ÉVÉNEMENTS
   ============================================================ */
function ajouterLog(texte, type = '') {
  const log = document.getElementById('log-evenements');
  if (!log) return;

  const now = new Date();
  const h = String(now.getHours()).padStart(2,'0');
  const m = String(now.getMinutes()).padStart(2,'0');

  const div = document.createElement('div');
  div.className = `log-entree ${type}`;
  div.innerHTML = `<span class="horodatage">${h}:${m}</span>${texte}`;
  log.appendChild(div);
  log.scrollTop = log.scrollHeight;

  // Limiter à 100 entrées
  while (log.children.length > 100) log.removeChild(log.firstChild);
}

/* ============================================================
   AUDIO
   ============================================================ */
/*
  POUR CONFIGURER L'AUDIO :
  Remplacez les URLs vides dans etat.pistesAmbiance par des URLs valides
  pointant vers vos fichiers audio (MP3, OGG, etc.).
  Exemple : { nom: 'Sanctuaire', url: 'https://votre-serveur.com/ambiance.mp3' }

  Sons d'événements :
  - Gong de nuit : éditez audioEvenements.gong.src
  - Cri d'attaque : éditez audioEvenements.cri.src
  - Cloches du matin : éditez audioEvenements.matin.src
*/
const audioEvenements = {
  gong:   'https://placeholder-audio.example/gong.mp3',    // Remplacez
  cri:    'https://placeholder-audio.example/cri.mp3',     // Remplacez
  matin:  'https://placeholder-audio.example/matin.mp3',  // Remplacez
};

function joueurSon(type) {
  if (etat.muet) return;

  if (type === 'ambiance') {
    const audio = document.getElementById('audio-ambiance');
    const piste = etat.pistesAmbiance[etat.piste];
    if (piste.url) {
      audio.src = piste.url;
      audio.play().catch(() => {});
    }
    document.getElementById('indicateur-piste').textContent = piste.nom;
    return;
  }

  const url = audioEvenements[type];
  if (!url || url.includes('placeholder')) return;
  const audio = document.getElementById('audio-evenement');
  audio.src = url;
  audio.play().catch(() => {});
}

function toggleAudio() {
  etat.muet = !etat.muet;
  document.getElementById('btn-audio-toggle').textContent = etat.muet ? '🔇' : '🔊';
  const ambianceAudio = document.getElementById('audio-ambiance');
  if (etat.muet) ambianceAudio.pause();
  else ambianceAudio.play().catch(() => {});
}

function changerPiste(direction) {
  etat.piste = (etat.piste + direction + etat.pistesAmbiance.length) % etat.pistesAmbiance.length;
  joueurSon('ambiance');
}

/* ============================================================
   NAVIGATION ENTRE ÉCRANS
   ============================================================ */
function changerEcran(idEcran) {
  document.querySelectorAll('.ecran').forEach(e => e.classList.remove('actif'));
  const cible = document.getElementById(idEcran);
  if (cible) cible.classList.add('actif');
}

function revenirAccueil() {
  // Réinitialisation
  Object.assign(etat, {
    estMJ: false, monId: null, monPseudo: null, monRole: null, sessionId: null,
    joueurs: {}, ordreJoueurs: [], phase: 'attente', nuit: 0,
    actionsNuit: {}, votes: {}, cibleSelectionne: null, voteSelectionne: null,
  });

  document.getElementById('zone-attente').style.display = 'none';
  document.getElementById('panneau-creer').style.display = 'block';
  document.getElementById('info-session').style.display = 'none';
  document.getElementById('mj-pseudo').value = '';
  document.getElementById('joueur-pseudo').value = '';
  document.getElementById('session-id').value = '';

  changerEcran('ecran-accueil');
  arreterTimer();
}

/* ============================================================
   NOTIFICATIONS TOAST
   ============================================================ */
function afficherToast(message, type = '') {
  const container = document.getElementById('toast-container');
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.textContent = message;
  container.appendChild(toast);

  setTimeout(() => {
    toast.style.animation = 'toastEntree 0.3s ease reverse';
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}

/* ============================================================
   UTILITAIRES
   ============================================================ */
function genererID() {
  return Date.now().toString(36) + Math.random().toString(36).substr(2, 5);
}

function melangerTableau(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

function jouveursVivantsSauf(exclure) {
  return etat.ordreJoueurs.filter(id => {
    const j = etat.joueurs[id];
    return j && j.vivant && id !== exclure;
  });
}

function mettreAJourStatutConnexion(connecte) {
  const dot = document.getElementById('dot-connexion');
  const texte = document.getElementById('texte-statut-connexion');
  if (connecte) {
    dot.classList.remove('deconnecte');
    texte.textContent = `Connecté au Sanctuaire (${etat.sessionId || ''})`;
  } else {
    dot.classList.add('deconnecte');
    texte.textContent = 'Connexion perdue...';
  }
}

/* ============================================================
   PARTICULES FLOTTANTES DE FOND
   ============================================================ */
function creerParticules() {
  const colors = ['rgba(139,0,0,0.6)', 'rgba(180,140,12,0.4)', 'rgba(100,0,0,0.5)'];
  for (let i = 0; i < 20; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.style.left = Math.random() * 100 + 'vw';
    p.style.setProperty('--drift', (Math.random() - 0.5) * 60 + 'px');
    p.style.background = colors[Math.floor(Math.random() * colors.length)];
    p.style.animationDuration = (8 + Math.random() * 12) + 's';
    p.style.animationDelay = Math.random() * 10 + 's';
    document.body.appendChild(p);
  }
}

